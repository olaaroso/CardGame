<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane stylesheets="@styling.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cardgame.CardGameController">
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="top-bar">
            <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
            <Button text="Find a Solution" disable="true" />
            <TextField disable="true" prefWidth="120" />
            <Button onAction="#handleRefresh" text="Refresh" styleClass="action-btn" />
        </HBox>
    </top>

    <center>
        <HBox fx:id="cardBox" alignment="CENTER" spacing="15" styleClass="card-container">
            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="10" styleClass="bottom-bar">
            <padding><Insets bottom="15" left="10" right="10" top="15" /></padding>
            <Label text="Enter an expression:" styleClass="bold-label" />
            <TextField fx:id="expressionField" prefWidth="220" />
            <Button onAction="#handleVerify" text="Verify" styleClass="action-btn" />
        </HBox>
    </bottom>
</BorderPane>